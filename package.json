{
  "name": "ai-fe-exam",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "check-husky": "if [ -z \"${DISABLE_HUSKY}\" ]; then yarn run setup:husky; fi",
    "setup:husky": "husky init && echo 'npx lint-staged' > .husky/pre-commit && chmod +x .husky/pre-commit",
    "prepare": "husky"
  },
  "dependencies": {
    "@formkit/vue": "^1.6.5",
    "axios": "^1.7.5",
    "flatpickr": "^4.6.13",
    "pinia": "^2.1.7",
    "sweetalert2": "^11.12.4",
    "vue": "^3.4.29",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.14.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.5",
    "npm-run-all2": "^6.2.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.4.0",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.21"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched",
      "biome check --write --organize-imports-enabled=false --no-errors-on-unmatched",
      "biome check --write --unsafe --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched",
      "biome lint --write --no-errors-on-unmatched"
    ]
  }
}
